"build": {
  "extraResources": [
    {
      "from": "../backend",
      "to": "backend",
      "filter": ["**/*", "!node_modules", "!.env"]
    },
    {
      "from": "bin",
      "to": "bin"
    }
  ],
  "extraFiles": [
    {
      "from": "../backend/node_modules",
      "to": "resources/backend/node_modules"
    }
  ]
}
