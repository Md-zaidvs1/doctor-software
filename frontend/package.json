{
  "name": "plant2tree-doctor-software",
  "version": "1.0.0",
  "description": "Plant2Tree Doctor Software for managing clinics",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "electron .",
    "electron:build": "electron-builder"
  },
  "dependencies": {
    "electron": "^28.0.0",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "vite": "^5.0.0",
    "electron-builder": "^24.6.0"
  },
  "build": {
    "appId": "com.plant2tree.doctorsoftware",
    "productName": "Plant2Tree Doctor Software",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "main.js"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!node_modules",
          "!.env"
        ]
      },
      {
        "from": "bin",
        "to": "bin"
      }
    ],
    "extraFiles": [
      {
        "from": "../backend/node_modules",
        "to": "backend/node_modules"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    }
  }
}
